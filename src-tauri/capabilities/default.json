{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissions granted to the main window and stable scoped windows created by the native shell.",
  "windows": [
    "main",
    "win-*"
  ],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "updater:default",
    "notification:default",
    "process:allow-restart"
  ]
}
