{
  "name": "prettyd",
  "private": true,
  "version": "0.1.0",
  "description": "Pretty PTY daemon — owns node-pty sessions, exposes them over HTTP + WS.",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "pretty": "bin/pretty.cjs"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "node scripts/fix-spawn-helper.cjs"
  },
  "dependencies": {
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
